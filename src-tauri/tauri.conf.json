{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "host-manager",
  "version": "1.0.3",
  "identifier": "com.host-manager.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "host-manager",
        "width": 800,
        "height": 600,
        "decorations": false,
        "resizable": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxRjFCRkE5MjQ2MEJDRDQKUldUVXZHQWtxYi94NGF5dTJYT1huWGd3aUdCbmNMaHJjMHBzWXpXTVVrdnFHQTg3UXBTTERkcW4K",
      "endpoints": [
        "https://github.com/ubiratanlsc/host-manager/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}