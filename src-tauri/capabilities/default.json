{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:scope",
    "fs:allow-app-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:write-all",
    "fs:allow-read",
    "fs:allow-read-dir",
    "fs:allow-app-read-recursive",
    "fs:allow-write",
    "fs:write-files",
    "fs:allow-app-write-recursive",
    "fs:allow-watch",
    "fs:allow-desktop-write-recursive",
    "fs:allow-data-read-recursive",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "system-fonts:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "fs:allow-app-write-recursive",
      "allow": [
        {
          "path": "$APPCONFIG/*"
        },
        {
          "path": "$APPDATA/*"
        },
        {
          "path": "$DESKTOP/*"
        },
        {
          "path": "$DOCUMENTS/*"
        },
        {
          "path": "$DOWNLOADS/*"
        },
        {
          "path": "$RESOURCE"
        }
      ]
    },
    {
      "identifier": "fs:allow-app-read-recursive",
      "allow": [
        {
          "path": "$APPCONFIG/*"
        },
        {
          "path": "$APPDATA/*"
        },
        {
          "path": "$DESKTOP/*"
        },
        {
          "path": "$DOCUMENTS/*"
        },
        {
          "path": "$DOWNLOADS/*"
        },
        {
          "path": "$RESOURCE/*"
        }
      ]
    }
  ]
}